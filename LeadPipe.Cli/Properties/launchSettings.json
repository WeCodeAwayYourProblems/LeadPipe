{
  "profiles": {
    // Example
    "Example - All Options Dev": {
      "commandName": "Project",
      "commandLineArgs": "example -f ./ -s ../ -t ../../../",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    "Example - No Options": {
      "commandName": "Project",
      "commandLineArgs": "example",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },

    // Data Reporting
    "Data report only": {
      "commandName": "Project",
      "commandLineArgs": "data -r",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    "Data report only | Yeller": {
      "commandName": "Project",
      "commandLineArgs": "data -r -s Yeller",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },

    // Data Updating
    "Data update only | Get all data": {
      "commandName": "Project",
      "commandLineArgs": "data -u",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    "Data update only | Refresh data": {
      "commandName": "Project",
      "commandLineArgs": "data -Ru",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },

    // Data Updating AND Reporting 
    "Data update and report | Get all data": {
      "commandName": "Project",
      "commandLineArgs": "data",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    "Data update and report | Refresh data": {
      "commandName": "Project",
      "commandLineArgs": "data -R",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    }
  }
}